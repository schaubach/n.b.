# Copy this file to .env and run scripts/setup.sh.
# Do not commit .env.

# Shared HMAC secret. Generate with scripts/setup.sh or: openssl rand -base64 48
NB_MAIL_PSK=

# HTTPS certificate subject. Use the server IP that iPads will call.
SERVER_NAME=10.97.0.10

# Basic-auth user for https://SERVER_IP:8123/installwebapp/
INSTALL_USER=install
# Set this in .env, not in the repository.
INSTALL_PASSWORD=

# SMTP configuration for IServ/RBBK.
SMTP_HOST=rbbk-do.de
SMTP_PORT=587
SMTP_STARTTLS=true
ALLOWED_DOMAIN=rbbk-do.de
# Optional: comma-separated sender allowlist. Empty means any sender in ALLOWED_DOMAIN.
# ALLOWED_SENDERS=lehrkraft1@rbbk-do.de,lehrkraft2@rbbk-do.de

# Request validation and abuse protection.
MAX_RECIPIENTS_PER_REQUEST=35
MAX_MESSAGE_BYTES=200000
MAX_SUBJECT_LENGTH=180
TIMESTAMP_WINDOW_SECONDS=300
NONCE_TTL_SECONDS=900
RATE_LIMIT_PER_MINUTE=180
RATE_LIMIT_PER_HOUR=400
RATE_LIMIT_PER_DAY=1200

# Optional CORS for development, comma-separated.
# In production the WebApp is normally served from the same nginx origin.
ALLOWED_ORIGINS=https://localhost:8123
